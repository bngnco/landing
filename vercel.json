{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "cleanUrls": false,
  "buildCommand": "node scripts/build-deploy.mjs",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.verifyco.app" }
      ],
      "destination": "https://verifyco.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "verifyco.info" }
      ],
      "destination": "https://verifyco.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.verifyco.info" }
      ],
      "destination": "https://verifyco.app/:path*",
      "permanent": true
    },
    { "source": "/blog/index.html", "destination": "/blog", "permanent": true },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog/index.html", "destination": "/:lang/blog", "permanent": true },
    { "source": "/blog/tag/:slug([a-z0-9-]+).html", "destination": "/blog/tag/:slug", "permanent": true },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog/tag/:slug([a-z0-9-]+).html", "destination": "/:lang/blog/tag/:slug", "permanent": true },
    { "source": "/blog/:slug([a-z0-9-]+).html", "destination": "/blog/:slug", "permanent": true },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog/:slug([a-z0-9-]+).html", "destination": "/:lang/blog/:slug", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/vera.html", "destination": "/vera", "permanent": true },
    { "source": "/deepdetect-plus.html", "destination": "/deepdetect-plus", "permanent": true },
    { "source": "/support.html", "destination": "/support", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/terms.html", "destination": "/terms", "permanent": true },
    { "source": "/sitemap.html", "destination": "/sitemap", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog", "destination": "/:lang/blog/index.html" },
    { "source": "/blog/tag/:slug([a-z0-9-]+)", "destination": "/blog/tag/:slug.html" },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog/tag/:slug([a-z0-9-]+)", "destination": "/:lang/blog/tag/:slug.html" },
    { "source": "/blog/:slug([a-z0-9-]+)", "destination": "/blog/:slug.html" },
    { "source": "/:lang(tr|es|de|fr|it|pt|ar)/blog/:slug([a-z0-9-]+)", "destination": "/:lang/blog/:slug.html" },
    { "source": "/vera", "destination": "/vera.html" },
    { "source": "/deepdetect-plus", "destination": "/deepdetect-plus.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/sitemap", "destination": "/sitemap.html" }
  ],
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }
      ]
    },
    {
      "source": "/uploads/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/:path*/feed.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
